{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "CCP Desktop",
  "version": "0.1.0",
  "identifier": "com.ccp.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CCP Desktop",
        "width": 960,
        "height": 680,
        "minWidth": 760,
        "minHeight": 500,
        "center": true,
        "visible": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
